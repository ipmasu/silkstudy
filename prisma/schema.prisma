generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  COUNSELOR
  ADMIN
  SUPER_ADMIN
}

enum DegreeLevel {
  LANGUAGE
  BACHELOR
  MASTER
  PHD
  NON_DEGREE
}

enum ProgramLanguage {
  ENGLISH
  CHINESE
  BILINGUAL
}

enum ConsultationStatus {
  NEW
  CONTACTED
  APPLIED
  CONVERTED
  LOST
}

enum MediaType {
  LOGO
  COVER
  PHOTO
  VIDEO
}

enum ScholarshipType {
  CSC
  PROVINCIAL
  UNIVERSITY
  CITY
  OTHER
}

enum AdminAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  EXPORT
  STATUS_CHANGE
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExternalReviewPlatform {
  DOUYIN
  TIKTOK
  XIAOHONGSHU
  YOUTUBE
  GOOGLE
  OTHER
}

enum ExternalReviewImportStatus {
  NEEDS_SOURCE_REVIEW
  NEEDS_PERMISSION
  READY_FOR_MODERATION
  IMPORTED
  REJECTED
}

enum TravelContentPlatform {
  QUNAR
  XIAOHONGSHU
  DIANPING
  DOUYIN
  TIKTOK
  TRIP
  OFFICIAL_TOURISM
  WIKIVOYAGE
  OTHER
}

enum TravelContentStatus {
  NEEDS_REWRITE
  NEEDS_SOURCE_REVIEW
  READY_TO_PUBLISH
  PUBLISHED
  REJECTED
}

enum CommunityPostType {
  MEETUP
  TRAVEL_BUDDY
  LANGUAGE_EXCHANGE
  CAMPUS_LIFE
  QUESTION
  LOCAL_HELP
}

enum CommunityPostStatus {
  PENDING
  APPROVED
  REJECTED
  CLOSED
}

enum CommunityReportReason {
  SPAM
  HARASSMENT
  UNSAFE_MEETUP
  PERSONAL_INFORMATION
  MISLEADING
  OTHER
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole   @default(STUDENT)
  country       String?
  phone         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts       Account[]
  sessions       Session[]
  consultations  Consultation[] @relation("ConsultationOwner")
  adminLogs      AdminLog[]
  assignedLeads  Consultation[] @relation("LeadAssignee")
  communityPosts CommunityPost[]
  communityReplies CommunityReply[]
  communityReports CommunityReport[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Province {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  nameZh          String?
  nameVi          String?
  description     String?  @db.Text
  bannerImageUrl  String?
  mapPath         String?  @db.Text
  latitude        Decimal? @db.Decimal(9, 6)
  longitude       Decimal? @db.Decimal(9, 6)
  universityCount Int      @default(0)
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cities       City[]
  universities University[]
  travelContentImports TravelContentImport[]
  seo          SeoMetadata?
}

model City {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  name                  String
  nameZh                String?
  nameVi                String?
  provinceId            String
  summary               String?  @db.Text
  livingCostMonthlyUsd  Int?
  climate               String?
  visaConvenience       String?
  studentReviewSummary  String?  @db.Text
  heroImageUrl          String?
  latitude              Decimal? @db.Decimal(9, 6)
  longitude             Decimal? @db.Decimal(9, 6)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  province     Province      @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  universities University[]
  consultations Consultation[]
  travelContentImports TravelContentImport[]
  seo          SeoMetadata?
  communityPosts CommunityPost[]

  @@index([provinceId])
}

model CommunityPost {
  id             String              @id @default(cuid())
  authorId       String?
  cityId         String?
  type           CommunityPostType
  status         CommunityPostStatus @default(PENDING)
  title          String
  content        String              @db.Text
  authorName     String
  authorCountry  String?
  languages      String[]            @default([])
  eventDate      DateTime?
  meetingArea    String?
  contactEmail   String?
  participantCap Int?
  isFeatured     Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  author  User?              @relation(fields: [authorId], references: [id], onDelete: SetNull)
  city    City?              @relation(fields: [cityId], references: [id], onDelete: SetNull)
  replies CommunityReply[]
  reports CommunityReport[]

  @@index([cityId])
  @@index([type])
  @@index([status, createdAt])
}

model CommunityReply {
  id         String       @id @default(cuid())
  postId     String
  authorId   String?
  authorName String
  content    String       @db.Text
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([postId, status])
}

model CommunityReport {
  id         String                @id @default(cuid())
  postId     String
  reporterId String?
  reason     CommunityReportReason
  details    String?               @db.Text
  createdAt  DateTime              @default(now())

  post     CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User?         @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([reason])
}

model GlobalCheckin {
  id                String       @id @default(cuid())
  countryCode       String
  countryName       String
  userName          String
  tagline           String       @db.Text
  countryCharm      String       @db.Text
  travelStudyReason String       @db.Text
  specialties       String       @db.Text
  status            ReviewStatus @default(APPROVED)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([countryCode])
  @@index([status, createdAt])
}

model BeautyExchange {
  id        String       @id @default(cuid())
  ownerName String
  country   String
  city      String
  title     String
  offer     String       @db.Text
  wish      String       @db.Text
  story     String       @db.Text
  shipping  String       @db.Text
  status    ReviewStatus @default(APPROVED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([country])
  @@index([status, createdAt])
}

model University {
  id                        String   @id @default(cuid())
  slug                      String   @unique
  name                      String
  chineseName               String?
  summary                   String?  @db.Text
  description               String?  @db.Text
  qsRanking                 Int?
  nationalRanking           Int?
  foundedYear               Int?
  website                   String?
  provinceId                String
  cityId                    String
  address                   String?
  internationalStudentCount Int?
  tuitionMinUsd             Int?
  tuitionMaxUsd             Int?
  dormitoryCostUsd          Int?
  livingCostMonthlyUsd      Int?
  hasEnglishPrograms        Boolean  @default(false)
  hasScholarships           Boolean  @default(false)
  applicationFeeUsd         Int?
  admissionEmail            String?
  campusLifeSummary         String?  @db.Text
  nearbyLivingSummary       String?  @db.Text
  nearbyAttractionsSummary  String?  @db.Text
  internshipCareerSummary   String?  @db.Text
  safetyAndTransportSummary String?  @db.Text
  isFeatured                Boolean  @default(false)
  isPublished               Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  province      Province          @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  city          City              @relation(fields: [cityId], references: [id], onDelete: Restrict)
  media         UniversityMedia[]
  programs      UniversityMajor[]
  scholarships  Scholarship[]
  consultations Consultation[]
  reviews       UniversityReview[]
  externalReviewImports ExternalReviewImport[]
  travelContentImports TravelContentImport[]
  seo           SeoMetadata?

  @@index([provinceId])
  @@index([cityId])
  @@index([name])
  @@index([qsRanking])
}

model UniversityReview {
  id           String       @id @default(cuid())
  universityId String
  authorName   String
  authorCountry String?
  program      String?
  degreeLevel  DegreeLevel?
  rating       Int
  title        String
  content      String       @db.Text
  pros         String?      @db.Text
  cons         String?      @db.Text
  status       ReviewStatus @default(PENDING)
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId])
  @@index([status])
  @@index([rating])
}

model ExternalReviewImport {
  id               String                     @id @default(cuid())
  universityId     String?
  platform         ExternalReviewPlatform
  sourceUrl        String
  sourceAuthor     String?
  sourceLocale     String?
  originalText     String                     @db.Text
  translatedText   String?                    @db.Text
  editorialSummary String?                    @db.Text
  consentStatus    String                     @default("UNVERIFIED")
  status           ExternalReviewImportStatus @default(NEEDS_SOURCE_REVIEW)
  sourceCapturedAt DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  university University? @relation(fields: [universityId], references: [id], onDelete: SetNull)

  @@index([universityId])
  @@index([platform])
  @@index([status])
  @@unique([platform, sourceUrl])
}

model TravelContentImport {
  id                String                @id @default(cuid())
  provinceId        String?
  cityId            String?
  universityId      String?
  platform          TravelContentPlatform
  sourceUrl         String
  sourceTitle       String?
  sourceAuthor      String?
  sourceLocale      String?
  originalExcerpt   String                @db.Text
  rewrittenSummary  String?               @db.Text
  highlights        String[]              @default([])
  studentAngle      String?               @db.Text
  complianceNotes   String?               @db.Text
  status            TravelContentStatus   @default(NEEDS_REWRITE)
  sourceCapturedAt  DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  province Province? @relation(fields: [provinceId], references: [id], onDelete: SetNull)
  city     City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  university University? @relation(fields: [universityId], references: [id], onDelete: SetNull)

  @@index([provinceId])
  @@index([cityId])
  @@index([universityId])
  @@index([platform])
  @@index([status])
  @@unique([platform, sourceUrl])
}

model UniversityMedia {
  id           String    @id @default(cuid())
  universityId String
  type         MediaType
  url          String
  alt          String?
  publicId     String?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId, type])
}

model Major {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  nameZh          String?
  nameVi          String?
  category        String
  description     String?  @db.Text
  futureCareer    String?  @db.Text
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  programs      UniversityMajor[]
  consultations Consultation[]
  seo           SeoMetadata?

  @@index([name])
  @@index([category])
}

model UniversityMajor {
  id                  String          @id @default(cuid())
  universityId        String
  majorId             String
  degreeLevel         DegreeLevel
  programLanguage     ProgramLanguage @default(ENGLISH)
  durationYears       Decimal?        @db.Decimal(3, 1)
  tuitionUsdPerYear   Int?
  applicationDeadline DateTime?
  intake              String?
  gpaRequirement      String?
  languageRequirement String?
  hskRequirement      String?
  ieltsRequirement    String?
  toeflRequirement    String?
  isPublished         Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  major      Major      @relation(fields: [majorId], references: [id], onDelete: Cascade)

  @@unique([universityId, majorId, degreeLevel, programLanguage])
  @@index([majorId])
  @@index([degreeLevel])
}

model Scholarship {
  id             String          @id @default(cuid())
  universityId   String?
  name           String
  type           ScholarshipType
  coverage       String          @db.Text
  eligibility    String?         @db.Text
  applicationUrl String?
  deadline       DateTime?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  university University? @relation(fields: [universityId], references: [id], onDelete: SetNull)

  @@index([universityId])
  @@index([type])
  @@unique([universityId, name])
}

model Consultation {
  id                String             @id @default(cuid())
  firstName         String
  lastName          String
  country           String
  email             String
  phone             String?
  targetDegree      DegreeLevel?
  targetMajor       String?
  budgetUsd         Int?
  preferredCity     String?
  notes             String?            @db.Text
  status            ConsultationStatus @default(NEW)
  source            String             @default("website")
  userId            String?
  assignedToId      String?
  universityId      String?
  cityId            String?
  majorId           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user         User?       @relation("ConsultationOwner", fields: [userId], references: [id], onDelete: SetNull)
  assignedTo   User?       @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  university   University? @relation(fields: [universityId], references: [id], onDelete: SetNull)
  city         City?       @relation(fields: [cityId], references: [id], onDelete: SetNull)
  major        Major?      @relation(fields: [majorId], references: [id], onDelete: SetNull)
  crmNotes     CRMNote[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model CRMNote {
  id             String   @id @default(cuid())
  consultationId String
  authorId       String?
  content        String   @db.Text
  createdAt      DateTime @default(now())

  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@index([consultationId])
}

model AdminLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AdminAction
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
}

model SeoMetadata {
  id            String   @id @default(cuid())
  metaTitle     String
  metaDescription String @db.Text
  canonicalUrl  String?
  ogTitle       String?
  ogDescription String?  @db.Text
  ogImageUrl    String?
  jsonLd        Json?
  provinceId    String?  @unique
  cityId        String?  @unique
  universityId  String?  @unique
  majorId       String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  province   Province?   @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  city       City?       @relation(fields: [cityId], references: [id], onDelete: Cascade)
  university University? @relation(fields: [universityId], references: [id], onDelete: Cascade)
  major      Major?      @relation(fields: [majorId], references: [id], onDelete: Cascade)
}
